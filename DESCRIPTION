Package: easybgm
Type: Package
Title: Extracting and Visualizing Bayesian Graphical Models
Version: 0.3.1
Authors@R: c(
  person("Karoline", "Huth", , "k.huth@uva.nl", role = c("aut", "cre"), 
        comment = c(ORCID = "0000-0002-0662-1591")), 
